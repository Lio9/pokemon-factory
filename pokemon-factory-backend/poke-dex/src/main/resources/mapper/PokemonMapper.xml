<?xml version="1.0" encoding="UTF-8"?>
<!--
  PokemonMapper 文件说明
  所属模块：poke-dex 后端模块。
  文件类型：数据库映射配置文件。
  核心职责：负责声明 SQL、结果映射和 Mapper 接口之间的绑定关系。
  阅读建议：建议结合对应 Java Mapper 接口与数据模型一起阅读。
  项目注释补全说明：本注释用于帮助后续维护时快速定位文件在整体架构中的职责。
-->

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lio9.pokedex.mapper.PokemonMapper">

    <!-- 查询宝可梦形态信息 -->
    <select id="selectPokemonForms" resultType="com.lio9.pokedex.model.PokemonForm">
        SELECT pf.* FROM pokemon_form pf
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>
    
    <!-- 查询宝可梦形态属性 -->
    <select id="selectPokemonFormTypes" resultType="com.lio9.pokedex.model.PokemonFormType">
        SELECT pft.* FROM pokemon_form_type pft
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>
    
    <!-- 查询宝可梦形态特性 -->
    <select id="selectPokemonFormAbilities" resultType="com.lio9.pokedex.model.PokemonFormAbility">
        SELECT pfa.* FROM pokemon_form_ability pfa
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>
    
    <!-- 查询宝可梦蛋群 -->
    <select id="selectPokemonEggGroups" resultType="com.lio9.pokedex.model.PokemonEggGroup">
        SELECT peg.* FROM pokemon_egg_group peg
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>
    
    <!-- 查询宝可梦技能 -->
    <select id="selectPokemonMoves" resultType="com.lio9.pokedex.model.PokemonMove">
        SELECT pm.* FROM pokemon_move pm
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>
    
    <!-- 查询进化链 -->
    <select id="selectEvolutionChains" resultType="com.lio9.pokedex.model.EvolutionChain">
        SELECT ec.* FROM evolution_chain ec
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>
    
    <!-- 查询技能 -->
    <select id="selectMoves" resultType="com.lio9.pokedex.model.Move">
        SELECT m.* FROM move m
        <if test="ew != null">
            ${ew.sqlSegment}
        </if>
    </select>

</mapper>
