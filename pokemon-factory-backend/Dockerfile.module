# Dockerfile 文件说明
# 所属模块：项目根目录。
# 文件类型：部署与运行配置文件。
# 核心职责：负责容器、代理或运行环境相关的基础配置。
# 阅读建议：建议关注端口、路径与镜像/进程行为设置。
# 项目注释补全说明：本注释用于帮助后续维护时快速定位文件在整体架构中的职责。

FROM maven:3.9.11-eclipse-temurin-17 AS build

ARG MODULE_PATH=battleFactory
ARG JAR_PATTERN=*.jar

WORKDIR /workspace

COPY pom.xml pom.xml
COPY common common
COPY user-module user-module
COPY pokeDex pokeDex
COPY battleFactory battleFactory

RUN mvn -pl ${MODULE_PATH} -am -DskipTests package
RUN cp /workspace/${MODULE_PATH}/target/${JAR_PATTERN} /workspace/app.jar

FROM eclipse-temurin:17-jre

WORKDIR /app

ENV JAVA_OPTS=""
ENV SQLITE_DB_PATH=/workspace/data/pokemon-factory.db

COPY --from=build /workspace/app.jar /app/app.jar

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar /app/app.jar"]