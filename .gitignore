# Pokemon Factory .gitignore

# ========================
# 敏感数据
# ========================
config/secrets.yml
secrets.json
credentials.json

# ========================
# Python (scripts/)
# ========================
__pycache__/
*.py[cod]
venv/
.venv/

# ========================
# Java / Maven
# ========================
target/
*.iws
*.iml
*.ipr
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml

# ========================
# 前端 (Node / Vite / Vue)
# ========================
node_modules/
dist/
.vite/
*.tsbuildinfo
npm-debug.log*
.npm-cache/

# ========================
# 数据库
# ========================
*.db
*.sqlite
*.sqlite3
!pokemon-factory-backend/common/src/main/resources/db/**/*.sql

# ========================
# IDE
# ========================
.vscode/
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.code-workspace

# ========================
# OS
# ========================
.DS_Store
Thumbs.db
[Dd]esktop.ini

# ========================
# 日志
# ========================
logs/
*.log
*.log.gz

# ========================
# 原始数据 (PokeAPI CSV)
# ========================
csv/

# ========================
# 临时文件
# ========================
*.tmp
*.bak
*.swp
